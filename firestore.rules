rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /projects/{projectId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.email == "tanaynaik0710@gmail.com";
    }
    match /meta/{docId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.email == "tanaynaik0710@gmail.com";
    }
  }
}
